# Copy this file to .env.microsoft (which is gitignored) and fill values.
# Use with: flutter run --dart-define-from-file=.env.microsoft

# Recommended default for multi-tenant school/work accounts.
# This matches your working backend setup that uses tenant='common'.
MS_TENANT_ID=common

# Optional - for reference only.
# Do not put MS_CLIENT_SECRET in flutter --dart-define files.
# Client secret must stay only in Firebase Console / secure backend config.
MS_CLIENT_ID=your-app-client-id

# Optional - helps prefill Microsoft account picker, e.g. calpoly.edu
MS_LOGIN_HINT_DOMAIN=calpoly.edu
